<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="JerjerBlenderBuilderUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:JerjerBlenderBuilderUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="StepCircle" TargetType="Ellipse">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Stroke" Value="{ThemeResource SystemAccentColor}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="Fill" Value="Transparent" />
        </Style>
        <Style x:Key="StepNumber" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*,Auto">
        <TextBlock Text="JERJER BLENDER BUILDER" FontSize="28" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Spacing="12" Margin="0,0,0,16">
            <TextBlock Text="Blender Source Directory:" FontSize="14" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox x:Name="SourceDirBox" PlaceholderText="C:\Users\...\blender" />
                <Button Grid.Column="1" Content="Browse" Click="OnBrowse" />
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="Progress:" FontSize="14" FontWeight="SemiBold" />
            <ProgressBar x:Name="ProgressBar" IsIndeterminate="False" Maximum="6" />
            <TextBlock x:Name="StepLabel" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
        </StackPanel>

        <Border Grid.Row="3" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" CornerRadius="6" Margin="0,0,0,12">
            <ScrollViewer>
                <TextBlock x:Name="LogOutput" FontFamily="Consolas" FontSize="12" Padding="8" TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
            <Button x:Name="StartButton" Content="Start Build" Click="OnStart" Style="{StaticResource AccentButtonStyle}" />
            <Button Content="Exit" Click="OnExit" />
        </StackPanel>
    </Grid>
</Page>
